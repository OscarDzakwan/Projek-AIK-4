-- 2. Jalankan INSERT gerakan
INSERT INTO `gerakan` (`id`, `id_kategori`, `nama`, `urutan`, `deskripsi`, `gambar_url`, `video_url`, `keterangan`) VALUES
(1, 1, 'Berdiri Tegak & Niat', 1, 'Berdiri tegak menghadap kiblat bagi yang mampu. Niat dilakukan di dalam hati, tanpa dilafalkan, karena tidak ada tuntunan dari Rasulullah SAW untuk melafalkannya.', NULL, NULL, 'Muhammadiyah tidak menganjurkan pelafalan niat karena tidak ada contohnya dari Rasulullah SAW; niat cukup sebagai kehendak hati.'),
(2, 1, 'Takbiratul Ihram', 2, 'Mengangkat kedua tangan sejajar bahu/telinga sambil mengucapkan "Allahu Akbar" sebagai pembuka sholat.', NULL, NULL, 'Gerakan mengangkat tangan mengacu pada hadits riwayat Bukhari-Muslim tentang tata cara takbiratul ihram Rasulullah SAW.'),
(3, 1, 'Bersedekap (Qiyam)', 3, 'Meletakkan tangan kanan di atas tangan kiri di dada. Pada posisi ini dibaca doa iftitah, ta\'awudz, basmalah, Al-Fatihah, dan surat/ayat Al-Qur\'an.', NULL, NULL, 'Posisi sedekap di dada adalah salah satu posisi yang dirajihkan (dipilih sebagai lebih kuat dalilnya) oleh Majelis Tarjih Muhammadiyah.'),
(4, 1, 'Ruku\'', 4, 'Membungkukkan badan dengan punggung dan kepala sejajar (lurus), kedua tangan memegang lutut, dilakukan dengan tuma\'ninah (tenang).', NULL, NULL, 'Tuma\'ninah (ketenangan/tidak tergesa-gesa) adalah rukun sholat yang wajib dijaga di setiap gerakan, termasuk ruku\'.'),
(5, 1, 'I\'tidal', 5, 'Bangkit dari ruku\' dengan mengangkat kedua tangan seperti saat takbiratul ihram, kemudian berdiri tegak kembali.', NULL, NULL, 'I\'tidal merupakan rukun tersendiri yang terpisah dari ruku\', bukan sekadar gerakan transisi.'),
(6, 1, 'Sujud Pertama', 6, 'Meletakkan dahi, hidung, kedua telapak tangan, kedua lutut, dan ujung jari kaki ke lantai. Ujung jari kaki menghadap kiblat, siku direnggangkan dari lambung.', NULL, NULL, 'Tujuh anggota badan (dahi-hidung, dua telapak tangan, dua lutut, dua ujung kaki) harus menempel ke lantai agar sujud sah.'),
(7, 1, 'Duduk di Antara Dua Sujud (Iftirasy)', 7, 'Duduk dengan tenang di antara dua sujud, mengangkat kepala sambil bertakbir.', NULL, NULL, 'Duduk iftirasy: telapak kaki kiri dijadikan alas duduk, telapak kaki kanan ditegakkan dengan jari menghadap kiblat.'),
(8, 1, 'Sujud Kedua', 8, 'Sujud kembali dengan tata cara yang sama seperti sujud pertama.', NULL, NULL, 'Menutup satu rangkaian gerakan dalam satu rakaat sebelum berdiri/duduk untuk rakaat berikutnya.'),
(9, 1, 'Duduk Tasyahud Awal', 9, 'Dilakukan pada rakaat kedua (untuk sholat yang jumlah rakaatnya lebih dari dua), membaca bacaan tasyahud awal.', NULL, NULL, 'Hanya ada pada sholat 3 atau 4 rakaat (mis. Maghrib, Dzuhur, Ashar, Isya\'); tidak ada pada sholat Subuh (2 rakaat).'),
(10, 1, 'Duduk Tasyahud Akhir (Tawarruk)', 10, 'Dilakukan pada rakaat terakhir, membaca tasyahud lengkap, sholawat Nabi, dan doa perlindungan.', NULL, NULL, 'Duduk tawarruk: pinggul menempel di lantai dengan kaki kiri diselipkan di bawah kaki kanan.'),
(11, 1, 'Salam', 11, 'Menoleh ke kanan lalu ke kiri sambil mengucapkan salam sebagai penutup sholat.', NULL, NULL, 'Menjadi penutup dan penanda selesainya sholat, sesuai hadits "kunci penutup sholat adalah salam"')
ON DUPLICATE KEY UPDATE 
 `nama`=VALUES(`nama`), `deskripsi`=VALUES(`deskripsi`), `keterangan`=VALUES(`keterangan`);

-- 3. Jalankan INSERT bacaan
INSERT INTO `bacaan` (`id_gerakan`, `urutan`, `teks_arab`, `teks_latin`, `terjemahan`, `audio_url`, `sumber`) VALUES
(2, 1, 'اللهُ أَكْبَرُ', 'Allaahu Akbar', 'Allah Maha Besar.', NULL, 'HPT Muhammadiyah'),
(3, 1, 'اَللّٰهُمَّ بَاعِدْ بَيْنِيْ وَبَيْنَ خَطَايَايَ كَمَا بَاعَدْتَ بَيْنَ الْمَشْرِقِ وَالْمَغْرِبِ، اَللّٰهُمَّ نَقِّنِيْ مِنَ الْخَطَايَا كَمَا يُنَقَّى الثَّوْبُ الْأَبْيَضُ مِنَ الدَّنَسِ، اَللّٰهُمَّ اغْسِلْ خَطَايَايَ بِالْمَاءِ وَالثَّلْجِ وَالْبَرَدِ', 'Allaahumma baa\'id bainii wa bainaa khathaayaaya kamaa baa\'adta bainal masyriqi wal maghrib. Allaahumma naqqinii minal khathaayaa kamaa yunaqqats tsaubul abyadhu minad danas. Allaahummaghsil khathaayaaya bil maa\'i wats tsalji wal barad', 'Ya Allah, jauhkanlah antara diriku dan kesalahan-kesalahanku sebagaimana Engkau jauhkan antara timur dan barat. Ya Allah, bersihkanlah aku dari kesalahan sebagaimana bersihnya kain putih dari kotoran. Ya Allah, cucilah kesalahan-kesalahanku dengan air, salju, dan embun.', NULL, 'HPT Muhammadiyah'),
(3, 2, 'بِسْمِ اللَّهِ الرَّحْمَٰنِ الرَّحِيمِ * الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ * الرَّحْمَٰنِ الرَّحِيمِ * مَالِكِ يَوْمِ الدِّينِ * إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ * اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ * صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ', 'Bismillaahir rahmaanir rahiim. Alhamdu lillaahi rabbil \'aalamiin. Ar-rahmaanir rahiim. Maaliki yaumid diin. Iyyaaka na\'budu wa iyyaaka nasta\'iin. Ihdinash shiraathal mustaqiim. Shiraathal ladziina an\'amta \'alaihim ghairil maghdhuubi \'alaihim wa ladh dhaalliin.', 'Dengan nama Allah Yang Maha Pengasih lagi Maha Penyayang. Segala puji bagi Allah, Tuhan semesta alam. Yang Maha Pengasih lagi Maha Penyayang. Yang menguasai hari pembalasan. Hanya kepada Engkau kami menyembah dan hanya kepada Engkau kami memohon pertolongan. Tunjukilah kami jalan yang lurus. Yaitu jalan orang-orang yang telah Engkau beri nikmat, bukan jalan mereka yang dimurkai dan bukan pula jalan mereka yang sesat.', NULL, 'Al-Qur\'an, Surat Al-Fatihah'),
(4, 1, 'سُبْحَانَ رَبِّيَ الْعَظِيمِ وَبِحَمْدِهِ', 'Subhaana rabbiyal \'azhiimi wa bihamdih (dibaca 3x)', 'Maha Suci Tuhanku Yang Maha Agung, dan dengan memuji-Nya.', NULL, 'HPT Muhammadiyah'),
(5, 1, 'سَمِعَ اللهُ لِمَنْ حَمِدَهُ، رَبَّنَا وَلَكَ الْحَمْدُ', 'Sami\'allaahu liman hamidah. Rabbanaa wa lakal hamd', 'Allah mendengar pujian dari orang yang memuji-Nya. Wahai Tuhan kami, bagi-Mu segala puji.', NULL, 'HPT Muhammadiyah'),
(5, 2, 'رَبَّنَا وَلَكَ الْحَمْدُ حَمْدًا كَثِيرًا طَيِّبًا مُبَارَكًا فِيهِ', 'Rabbanaa wa lakal hamdu hamdan katsiiran thayyiban mubaarakan fiih', 'Wahai Tuhan kami, bagi-Mu segala puji, pujian yang banyak, baik, dan penuh berkah.', NULL, 'HPT Muhammadiyah'),
(6, 1, 'سُبْحَانَكَ اللَّهُمَّ رَبَّنَا وَبِحَمْدِكَ اللَّهُمَّ اغْفِرْ لِيْ', 'Subhaanakallaahumma rabbanaa wa bihamdika Allaahummaghfir lii', 'Maha Suci Engkau, ya Allah, Tuhan kami, dan dengan memuji-Mu, ya Allah, ampunilah aku.', NULL, 'HPT Muhammadiyah'),
(7, 1, 'اَللَّهُمَّ اغْفِرْ لِيْ وَارْحَمْنِيْ وَاجْبُرْنِيْ وَاهْدِنِيْ وَارْزُقْنِيْ', 'Allaahummaghfir lii warhamnii wajburnii wahdinii warzuqnii', 'Ya Allah, ampunilah aku, kasihanilah aku, cukupilah aku, tunjukilah aku, dan berilah aku rezeki.', NULL, 'HPT Muhammadiyah'),
(8, 1, 'سُبْحَانَكَ اللَّهُمَّ رَبَّنَا وَبِحَمْدِكَ اللَّهُمَّ اغْفِرْ LII', 'Subhaanakallaahumma rabbanaa wa bihamdika Allaahummaghfir lii', 'Maha Suci Engkau, ya Allah, Tuhan kami, dan dengan memuji-Mu, ya Allah, ampunilah aku.', NULL, 'HPT Muhammadiyah'),
(9, 1, 'اَلتَّحِيَّاتُ لِلَّهِ وَالصَّلَاواتُ وَالطَّيِّبَاتُ، اَلسَّلَامُ عَلَيْكَ أَيُّهَا NABIYYU WA RAHMATULLAAHI WA BARAKAATUH. ASSALAAMU \'ALAINAA WA \'ALA \'IBAADILLAAHISH SHAALIHIIN. ASYHADU ALLAA ILAAHA ILLALLAAH WA ASYHADU ANNA MUHAMMADAN \'ABDUHU WA RASUULUH', 'Attahiyyaatu lillaahi wash shalawaatu wath thayyibaat. Assalaamu \'alaika ayyuhan nabiyyu wa rahmatullaahi wa barakaatuh. Assalaamu \'alainaa wa \'ala \'ibaadillaahish shaalihiin. Asyhadu allaa ilaaha illallaah wa asyhadu anna Muhammadan \'abduhu wa rasuuluh', 'Segala penghormatan, doa, dan kebaikan adalah milik Allah. Semoga keselamatan tercurah kepadamu wahai Nabi, beserta rahmat Allah dan berkah-Nya. Semoga keselamatan tercurah kepada kami dan hamba-hamba Allah yang saleh. Aku bersaksi tidak ada Tuhan selain Allah, dan aku bersaksi bahwa Muhammad adalah hamba dan utusan-Nya.', NULL, 'HPT Muhammadiyah'),
(9, 2, 'اَللَّهُمَّ إِنِّيْ ظَلَمْتُ نَفْسِيْ ظُلْمًا كَثِيْرًا وَلَا يَغْفِرُ DZUNUUBA ILLAA ANTA FAGHFIR LII MAGHFIRATAN MIN \'INDIKA WARHAMNII INNAKA ANTAL GHAFUURUR RAHIIM', 'Allaahumma innii zhalamtu nafsii zhulman katsiiraa, wa laa yaghfirudz dzunuuba illaa anta, faghfir lii maghfiratan min \'indika warhamnii, innaka antal ghafuurur rahiim', 'Ya Allah, sesungguhnya aku telah menzalimi diriku sendiri dengan kezaliman yang banyak, dan tidak ada yang mengampuni dosa selain Engkau. Maka ampunilah aku dengan ampunan dari sisi-Mu, dan kasihanilah aku. Sesungguhnya Engkau Maha Pengampun lagi Maha Penyayang.', NULL, 'HPT Muhammadiyah'),
(10, 1, 'اَلتَّحِيَّاتُ لِلَّهِ وَالصَّلَاواتُ وَالطَّيِّبَاتُ، اَلسَّلَامُ عَلَيْكَ أَيُّهَا NABIYYU WA RAHMATULLAAHI WA BARAKAATUH. ASSALAAMU \'ALAINAA WA \'ALAA \'IBAADILLAAHISH SHAALIHIIN. ASYHADU ALLAA ILAAHA ILLALLAAH WA ASYHADU ANNA MUHAMMADAN \'ABDUHU WA RASUULUH', 'Attahiyyaatu lillaahi wash shalawaatu wath thayyibaat. Assalaamu \'alaika ayyuhan nabiyyu wa rahmatullaahi wa barakaatuh. Assalaamu \'alainaa wa \'alaa \'ibaadillaahish shaalihiin. Asyhadu allaa ilaaha illallaah wa asyhadu anna Muhammadan \'abduhu wa rasuuluh', 'Segala penghormatan, doa, dan kebaikan adalah milik Allah. Semoga keselamatan tercurah kepadamu wahai Nabi, beserta rahmat Allah dan berkah-Nya. Semoga keselamatan tercurah kepada kami dan hamba-hamba Allah yang saleh. Aku bersaksi tidak ada Tuhan selain Allah, dan aku bersaksi bahwa Muhammad adalah hamba dan utusan-Nya.', NULL, 'HPT Muhammadiyah'),
(10, 2, 'اَللَّهُمَّ صَلِّ عَلَى مُحَمَّدٍ وَعَلَى آلِ مُحَمَّدٍ كَمَا صَلَّيْتَ عَلَى إِبْرَاهِيْمَ وَعَلَى آلِ إِبْرَاهِيْمَ إِنَّكَ حَمِيْدٌ مَجِيْدٌ', 'Allaahumma shalli \'alaa Muhammadin wa \'alaa aali Muhammadin kamaa shallaita \'alaa Ibraahiima wa \'alaa aali Ibraahiim, innaka hamiidun majiid', 'Ya Allah, limpahkanlah shalawat kepada Nabi Muhammad dan keluarganya, sebagaimana Engkau limpahkan kepada Nabi Ibrahim dan keluarganya. Sesungguhnya Engkau Maha Terpuji lagi Maha Mulia.', NULL, 'HPT Muhammadiyah'),
(10, 3, 'اَللَّهُمَّ إِنِّيْ أَعُوْذُ بِكَ مِنْ عَذَابِ JAHANNAM WA MIN \'ADZAABIL QABRI WA MIN FITNATIL MAHYAA WAL MAMAATI WA MIN SYARRI FITNATIL MASIIHID DAJJAAL', 'Allaahumma innii a\'uudzu bika min \'adzaabi jahannam, wa min \'adzaabil qabri, wa min fitnatil mahyaa wal mamaati, wa min syarri fitnatil masiihid dajjaal', 'Ya Allah, aku berlindung kepada-Mu dari siksa jahannam, siksa kubur, fitnah hidup dan mati, serta keburukan fitnah Al-Masih Dajjal.', NULL, 'HPT Muhammadiyah'),
(11, 1, 'اَلسَّلَامُ عَلَيْكُمْ وَرَحْمَةُ اللهِ وَبَرَكَاتُهُ', 'Assalaamu \'alaikum wa rahmatullaahi wa barakaatuh', 'Semoga keselamatan, rahmat Allah, dan berkah-Nya tercurah atas kalian (menoleh ke kanan).', NULL, 'HPT Muhammadiyah'),
(11, 2, 'اَلسَّلَامُ عَلَيْكُمْ وَرَحْمَةُ اللهِ وَبَرَكَاتُهُ', 'Assalaamu \'alaikum wa rahmatullaahi wa barakaatuh', 'Semoga keselamatan, rahmat Allah, dan berkah-Nya tercurah atas kalian (menoleh ke kiri).', NULL, 'HPT Muhammadiyah');

